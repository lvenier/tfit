{
    "name": "box4fit",
    "main": "main.js",
    "version": "1.11.3",
    "description": "A webcam boxing fitness game with motion detection",
    "license": "ISC",
    "author": {
        "name": "saashup.com",
        "email": "contact@box4.fit",
        "url": "https://box4.fit"
    },
    "scripts": {
        "start": "electron .",
        "serve": "http-server . -p 8000 -c-1",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "node --test tests/unit/*.test.js",
        "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
        "test:e2e:headed": "node ./node_modules/@playwright/test/cli.js test --headed",
        "build-linux": "npx electron-builder --linux",
        "build-win": "npx electron-builder --win"
    },
    "build": {
        "appId": "app.box4.fit",
        "productName": "Box4Fit",
        "linux": {
            "icon": "assets/logos/logo.256.png",
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Game"
        },
        "win": {
            "target": "nsis",
            "icon": "assets/logos/logo.256.png"
        }
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "electron": "*",
        "electron-builder": "*",
        "electron-packager": "*",
        "http-server": "^14.1.1"
    }
}
