{
    "name": "box4fit",
    "desktopName": "Box4Fit",
    "main": "main.js",
    "version": "1.18.4",
    "description": "A webcam boxing fitness game with motion detection",
    "license": "MIT",
    "keywords": [
        "boxing",
        "fitness",
        "workout",
        "game",
        "ml5",
        "webcam",
        "javascript",
        "training",
        "box4fit"
    ],
    "author": {
        "name": "saashup.com",
        "email": "contact@box4.fit",
        "url": "https://box4.fit"
    },
    "scripts": {
        "start": "electron .",
        "serve": "npm run generate-version && http-server . -p 8000 -c-1",
        "generate-version": "node scripts/generate-version.js",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "vitest run --config vitest.unit.config.mjs",
        "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
        "test:e2e:headed": "node ./node_modules/@playwright/test/cli.js test --headed",
        "build-linux": "npx electron-builder --linux --publish never",
        "build-win": "npx electron-builder --win --publish never"
    },
    "build": {
        "appId": "app.box4.fit",
        "productName": "Box4Fit",
        "asarUnpack": [
            "assets/models/face-recognition/**/*",
            "assets/vendor/onnxruntime-web/**/*"
        ],
        "linux": {
            "icon": "assets/logos/logo.256.png",
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Game",
            "syncDesktopName": true
        },
        "win": {
            "target": "nsis",
            "icon": "assets/logos/logo.256.png"
        }
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@vitest/coverage-v8": "^4.1.8",
        "electron": "*",
        "electron-builder": "*",
        "electron-packager": "*",
        "http-server": "^14.1.1",
        "jsdom": "^29.1.1",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "onnxruntime-web": "^1.27.0"
    }
}
